# Copy to tests/e2e/.env.remote and fill in values for the public target.
# The real .env.remote file is ignored because it contains reusable test
# account credentials.
REMOTE_E2E=1
PLAYWRIGHT_BASE_URL=https://webmail.stage-thundermail.com
JMAP_BASE_URL=https://jmap.stage-thundermail.com
OIDC_ISSUER=https://auth-stage.tb.pro/realms/tbpro
OIDC_CLIENT_ID="thunderbird-stormbox-test"
TEST_OIDC_EMAIL=
TEST_OIDC_PASSWORD=
TEST_THUNDERMAIL=

# Optional: only needed for specs that inject mail through SMTP.
SMTP_HOST="mail.stage-thundermail.com"
SMTP_TLS_PORT=465
TEST_SMTP_PASSWORD=

# Optional: needed when running on BrowserStack
BROWSERSTACK_USERNAME="your-browserstack-user-name"
BROWSERSTACK_ACCESS_KEY="your-browserstack-access-key"
