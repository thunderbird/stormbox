# Copy to tests/e2e/.env.local and adjust if your provisioned address differs.
# Defaults below match the dedicated e2e account that
# tests/fixtures/configure-{keycloak,stalwart}.mjs auto-provisions
# (kept distinct from the developer's admin@example.org account).
LOCAL_STACK=1
TEST_OIDC_EMAIL=e2e@example.org
TEST_OIDC_PASSWORD=e2e
TEST_THUNDERMAIL=e2e@example.org
# Authenticated SMTP app password created by npm run stack:configure.
# This is intentionally different from the OIDC password — it's the
# argon2id-hashed literal "admin" stored as an app-password on the
# e2e principal in Stalwart. Don't change it without also rehashing
# in configure-stalwart.mjs.
TEST_SMTP_PASSWORD=admin
# Node-side JMAP helpers talk to Stalwart directly (not via the Vite proxy).
JMAP_BASE_URL=http://localhost:8081
# Browser OIDC goes through the Vite HTTPS proxy; leave unset to use playwright defaults.
# VITE_OIDC_ISSUER=https://localhost:3000/realms/tbpro
OIDC_CLIENT_ID=thunderbird-stormbox-test
