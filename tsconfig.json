{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "jsx": "preserve",

    // Strictness: type-checking is on, but the codebase is being
    // converted from JS so we leave a few rules off and rely on call-
    // site discipline + the canonical types in src/types.
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,

    // Allow .js neighbours during the migration. Stragglers stay
    // untyped (checkJs: false) so they don't gate the typecheck.
    "allowJs": true,
    "checkJs": false,

    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "src/**/*.js",
    "tests/unit/**/*.ts",
    "tests/unit/**/*.js",
    "vite.config.*",
    "playwright.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "thunderbird-accounts",
    "tests/e2e/**",
    "tests/perf/**",
    "tests/fixtures/**"
  ]
}
