# Optional overrides (copy to .env.local; gitignored).
# .env.development already points dev at the local stack.

# When Vite runs inside the dev container, proxies must reach the host:
# STORMBOX_IN_DOCKER=1
# KEYCLOAK_PROXY=http://172.17.0.1:8999
# STALWART_JMAP_PROXY=http://172.17.0.1:8081

# When Vite runs on the host directly:
# KEYCLOAK_PROXY=http://127.0.0.1:8999
# STALWART_JMAP_PROXY=http://127.0.0.1:8081

# WS auth proxy (run: npm run stack:ws-proxy)
# UPSTREAM_BASE=http://127.0.0.1:8081
